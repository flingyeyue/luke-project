{
  "name": "@luke/file-adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./csv": {
      "types": "./src/csv.ts",
      "import": "./src/csv.ts"
    },
    "./export": {
      "types": "./src/export.ts",
      "import": "./src/export.ts"
    },
    "./xlsx": {
      "types": "./src/xlsx.ts",
      "import": "./src/xlsx.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@luke/contracts": "workspace:*",
    "exceljs": "4.4.0",
    "papaparse": "5.5.4"
  },
  "devDependencies": {
    "@types/papaparse": "5.5.2",
    "vitest": "4.1.10"
  }
}
